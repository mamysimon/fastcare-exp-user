<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:api-gateway="http://www.mulesoft.org/schema/mule/api-gateway" xmlns:apikit="http://www.mulesoft.org/schema/mule/mule-apikit" xmlns:calendar-system-api="http://www.mulesoft.org/schema/mule/calendar-system-api" xmlns:database-system-api="http://www.mulesoft.org/schema/mule/database-system-api" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns:http="http://www.mulesoft.org/schema/mule/http" xmlns:patient-process-api="http://www.mulesoft.org/schema/mule/patient-process-api" xmlns:secure-properties="http://www.mulesoft.org/schema/mule/secure-properties" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation=" http://www.mulesoft.org/schema/mule/mule-apikit http://www.mulesoft.org/schema/mule/mule-apikit/current/mule-apikit.xsd  http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd http://www.mulesoft.org/schema/mule/secure-properties http://www.mulesoft.org/schema/mule/secure-properties/current/mule-secure-properties.xsd http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd http://www.mulesoft.org/schema/mule/api-gateway http://www.mulesoft.org/schema/mule/api-gateway/current/mule-api-gateway.xsd http://www.mulesoft.org/schema/mule/patient-process-api http://www.mulesoft.org/schema/mule/patient-process-api/current/mule-patient-process-api.xsd http://www.mulesoft.org/schema/mule/database-system-api http://www.mulesoft.org/schema/mule/database-system-api/current/mule-database-system-api.xsd http://www.mulesoft.org/schema/mule/calendar-system-api http://www.mulesoft.org/schema/mule/calendar-system-api/current/mule-calendar-system-api.xsd">
    <http:listener-config name="exp-user-api-httpListenerConfig" basePath="${application.base-path}">
        <http:listener-connection host="0.0.0.0" port="${https.port}" />
    </http:listener-config>
    <apikit:config name="exp-user-api-config" api="resource::43c948fb-024c-4176-a702-879840dedb82:user-experience-api:1.0.9:raml:zip:user-experience-api.raml" outboundHeadersMapName="outboundHeaders" httpStatusVarName="httpStatus" queryParamsStrictValidation="true" />
    <configuration-properties doc:name="Configuration common properties" doc:id="33c029f3-7ef6-4940-9415-818e44cf94ea" file="properties/common-properties.yaml" />
    <configuration-properties doc:name="Configuration properties" doc:id="a627d6e9-4446-4ab1-b556-586aacd7e204" file="properties/${mule.env}-properties.yaml" />
    <api-gateway:autodiscovery apiId="${autodiscoveryId}" ignoreBasePath="true" doc:name="API Autodiscovery" doc:id="b5c8f22a-bc10-4b25-8eb9-90ffbda087f3" flowRef="exp-user-api-main" />
    <configuration doc:name="Configuration" doc:id="f57341c7-fbe5-4815-936d-34cdd39254e9" defaultErrorHandler-ref="globalsError_Handler" />
    <patient-process-api:config name="Patient_Process_API_Config" doc:name="Patient Process API Config" doc:id="171b15de-7525-48ae-aa4c-4e768966e2a1" property_host="${patient.host}" property_port="${patient.port}" property_basePath="${patient.base-path}" property_protocol="${protocol}" property_client-id="${patient.client-id}" property_client-secret="${patient.client-secret}" />
    <database-system-api:config name="Database_System_API_Config" doc:name="Database System API Config" doc:id="e7c8cc34-146d-496b-bfaf-f13924f3b6d3" property_host="${database.host}" property_port="${database.port}" property_basePath="${database.base-path}" property_protocol="${protocol}" property_client-id="${database.client-id}" property_client-secret="${database.client-secret}" />
    <calendar-system-api:config name="Calendar_System_API_Config" doc:name="Calendar System API Config" doc:id="f994570d-406e-4d97-a3dd-4ffdab873f13" property_host="${calendar.host}" property_port="${calendar.port}" property_basePath="${calendar.base-path}" property_protocol="${protocol}" property_client-id="${calendar.client-id}" property_client-secret="${calendar.client-secret}" />
    <sub-flow name="genericError" doc:id="924dcda8-a5cf-46d3-b12f-a585751fea50">
        <set-variable value="#[error.errorType.identifier match {&#xA;  case &quot;BAD_REQUEST&quot;            -&gt; 400&#xA;  case &quot;UNAUTHORIZED&quot;           -&gt; 401&#xA;  case &quot;FORBIDDEN&quot;              -&gt; 403&#xA;  case &quot;NOT_FOUND&quot;              -&gt; 404&#xA;  case &quot;METHOD_NOT_ALLOWED&quot;     -&gt; 405&#xA;  case &quot;NOT_ACCEPTABLE&quot;         -&gt; 406&#xA;  case &quot;CONFLICT&quot;                -&gt; 409&#xA;  case &quot;UNSUPPORTED_MEDIA_TYPE&quot; -&gt; 415&#xA;  case &quot;NOT_IMPLEMENTED&quot;        -&gt; 501&#xA;  else                          -&gt; error.errorMessage.attributes.statusCode default vars.httpStatus default 500&#xA;}]" doc:name="[httpStatus]" doc:id="4166b7c9-1ee6-4b75-9170-df4821512c8c" variableName="httpStatus" />
        <ee:transform doc:name="Standard Error" doc:id="dd9dbbd1-1fd1-4607-b841-941fb8f9fe8a">
            <ee:message>
                <ee:set-payload resource="modules/StandardError.dwl" />
            </ee:message>
        </ee:transform>
        <logger level="ERROR" doc:name="ERROR" doc:id="a0833285-47dc-4907-a6cb-34855ee4c7dd" message="#[{&#xA; step: &quot;Global error handler&quot;,&#xA; data: {&#xA;  business: {},&#xA;  technical: payload&#xA; }&#xA;}]" category="${app.name}" />
    </sub-flow>
    <error-handler name="globalsError_Handler" doc:id="4e6c82c1-1022-4ce4-a607-fcd5f16f1aa5">
        <on-error-propagate enableNotifications="true" logException="true" doc:name="role is invalid" doc:id="caf48a9d-1676-4070-90f5-0037e83c959f" type="PATIENT:FORBIDDEN">
            <set-variable value="#[&quot;A $(vars.role) cannot perform this action.&quot;]" doc:name="[description]" doc:id="9f3795ff-423b-4099-90eb-0d90bbc59ab6" variableName="description" />
            <set-variable value="403" doc:name="[httpStatus]" doc:id="a7cf9546-fdce-457e-ac00-43491bf349e8" variableName="httpStatus" />
            <flow-ref doc:name="genericError" doc:id="fbd47efc-711d-4dbe-8f51-2ea757bdf377" name="genericError" />
        </on-error-propagate>
        <on-error-propagate enableNotifications="true" logException="true" doc:name="cannot enter exactDate and fromDate" doc:id="f9ae7b93-5e60-413c-a616-bc5b8ce188e7" type="CALENDAR:BAD_REQUEST">
            <set-variable value="You cannot enter both exactDate and fromDate at the same time." doc:name="[description]" doc:id="19f3d34c-c848-413f-81af-ac56b6c95d61" variableName="description" />
            <set-variable value="400" doc:name="[httpStatus]" doc:id="bc09de4b-d832-4e23-86d3-d48eac13a901" variableName="httpStatus" />
            <flow-ref doc:name="genericError" doc:id="3bfb343d-c9e2-47c6-a22b-c9aeb66fbc3a" name="genericError" />
        </on-error-propagate>
        <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="1647bce7-4967-4420-bb1b-91170148787d">
            <flow-ref doc:name="genericError" doc:id="71506bee-a65b-44f6-9761-ed1c88dbc8cd" name="genericError" />
        </on-error-propagate>
    </error-handler>
</mule>
